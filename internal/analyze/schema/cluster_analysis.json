{
  "name": "cluster_analysis",
  "strict": true,
  "schema": {
    "type": "object",
    "required": ["summary", "severity", "root_cause_hypothesis", "suggested_actions", "confidence"],
    "additionalProperties": false,
    "properties": {
      "summary": {"type": "string", "minLength": 10, "maxLength": 400},
      "severity": {"type": "string", "enum": ["info", "warning", "critical"]},
      "root_cause_hypothesis": {"type": "string", "minLength": 10, "maxLength": 500},
      "suggested_actions": {
        "type": "array",
        "items": {"type": "string", "minLength": 10, "maxLength": 300},
        "minItems": 1,
        "maxItems": 5
      },
      "related_cluster_ids": {
        "type": "array",
        "items": {"type": "string"},
        "maxItems": 10
      },
      "confidence": {"type": "number", "minimum": 0, "maximum": 1}
    }
  }
}
